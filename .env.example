NEXT_PUBLIC_BIZDELI_API_KEY="your-bizdeli-api-key"

# Vercel Blob のアクセストークン。
# Vercel ダッシュボード Storage → Blob → .env.local Tab で取得。
# ローカル開発時は `vercel env pull` で同期するか、本値をセットすること。
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
